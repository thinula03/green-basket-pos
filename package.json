{
  "name": "grocery-offline-pos",
  "version": "1.0.0",
  "productName": "Green Basket POS",
  "description": "Reusable offline Electron POS system for grocery shops.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/renderer.js",
    "verify": "npm run check && npm audit",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "pos",
    "offline",
    "grocery",
    "open-source",
    "desktop-app",
    "beginner-friendly"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "build": {
    "appId": "com.greenbasket.offlinepos",
    "productName": "Green Basket POS",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json",
      "README.md",
      "RELEASE.md",
      "LICENSE"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "identity": null
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "26.15.3"
  }
}
